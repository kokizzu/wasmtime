;;! target = "aarch64"
;;! test = "winch"

(module
  (memory 1)
  (func (export "run")
    (v128.store (i32.const 0)
      (i64x2.add
        (v128.const i64x2 100 200)
        (v128.const i64x2 7 9)))))
